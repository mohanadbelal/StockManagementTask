@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid mt-4">
    <h2>Dashboard</h2>
    <hr />

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Materials</h5>
                    <h2>@Model.TotalMaterial</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Stock In Transactions</h5>
                    <h2>@Model.StockIn</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">Stock Out Transactions</h5>
                    <h2>@Model.StockOut</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h5 class="card-title">Low Stock Items</h5>
                    <h2>@Model.LowStockItem</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Quick Links</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">
                            <a asp-action="Index" asp-controller="Materials">View Materials</a>
                        </li>
                        <li class="list-group-item">
                            <a asp-action="Index" asp-controller="StockTransactions">View Transactions</a>
                        </li>
                        @if (User.IsInRole("Normal"))
                        {
                            <li class="list-group-item">
                                <a asp-action="Create" asp-controller="Materials">Add New Material</a>
                            </li>
                            <li class="list-group-item">
                                <a asp-action="Create" asp-controller="StockTransactions">Add New Stock Transaction</a>
                            </li>
                        }
                        
                        
                        
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
