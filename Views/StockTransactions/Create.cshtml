@model List<Assignment.Task.Models.Material>
@{
    ViewData["Title"] = "New Stock Transaction";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>Record Stock Transaction</h2>
            <hr />
            
            <form method="post" asp-action="Create" asp-controller="StockTransactions">
                @Html.AntiForgeryToken()
                
                <div class="mb-3">
                    <label for="materialId" class="form-label">Select Material</label>
                    <select class="form-control" id="materialId" name="materialId" required>
                        <option value="">-- Select Material --</option>
                        @foreach (var material in Model)
                        {
                            <option value="@material.Id">@material.Name</option>                          
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label for="TransactionType" class="form-label">Transaction Type</label>
                    <select class="form-control" id="TransactionType" name="TransactionType" required>
                        <option value="">-- Select Type --</option>
                        <option value="1">Stock In</option>
                        <option value="0">Stock Out</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="Quantity" class="form-label">Quantity</label>
                    <input type="number" class="form-control" id="Quantity" name="Quantity" step="0.01" required />
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Record Transaction</button>
                    <a asp-action="Index" asp-controller="StockTransactions" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
