@model List<Assignment.Task.Models.Material>

@{
    ViewData["Title"] = "Materials Listing";
}

<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h2>Materials</h2>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Normal")){
                <a asp-action="Create" asp-controller="Materials" class="btn btn-success">Add New Material</a>
            }
            
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Color</th>
                    <th>Current Stock</th>
                    <th>Minimum Required Stock</th>
                    <th>Created Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var material in Model)
                    {
                        <tr class="@(material.CurrentStock <= material.MinimumRequiredStock ? "table-danger" : "")">
                            <td>@material.Id</td>
                            <td>@material.Name</td>
                            <td>@material.Color</td>
                            <td>@material.CurrentStock</td>
                            <td>@material.MinimumRequiredStock</td>
                            <td>@material.CreatedAt.ToString("MM/dd/yyyy")</td>
                            @if(User.IsInRole("Normal")){
                                <td>
                                    <a asp-action="Edit" asp-controller="Materials" asp-route-id="@material.Id" class="btn btn-sm btn-primary">Edit</a>
                                    <a asp-action="Delete" asp-controller="Materials" asp-route-id="@material.Id" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</a>
                                </td>
                            }
                            
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">No materials found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

