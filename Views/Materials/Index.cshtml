@{
    ViewData["Title"] = "Materials Listing";
}

<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h2>Materials</h2>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" asp-controller="Materials" class="btn btn-success">Add New Material</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Current Stock</th>
                    <th>Unit</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- TODO: Populate with materials data -->
                <tr>
                    <td colspan="6" class="text-center text-muted">No materials found</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
